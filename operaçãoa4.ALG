Algoritmo "semnome"

Var
N1, N2, Resultado:real
Inicio
escreva("Entrada com N1:")
leia(N1)
escreva("Entrada com N2:")
leia(N2)
Resultado<-(N1+N2)
escreva("O resultado da soma:",Resultado)


escreva("Entrada com N1:")
leia(N1)
escreva("Entrada com N2:")
leia(N2)
Resultado<-(N1-N2)
escreva("O resultado da subtrašŃo:",Resultado)


escreva("Entrada com N1:")
leia(N1)
escreva("Entrada com N2:")
leia(N2)
Resultado<-(N1/N2)
escreva("O resultado da divisŃo:",Resultado)


escreva("Entrada com N1:")
leia(N1)
escreva("Entrada com N2:")
leia(N2)
Resultado<-(N1*N2)
escreva("O resultado da multiplicašŃo:",Resultado)
fimalgoritmo
