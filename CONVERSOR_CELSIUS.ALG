Algoritmo "conversor_celsius->fahrenheit"

Var
Celsius:real
Fahrenheit:real
Inicio
Escreva("Insira a quantidade de graus Celsius:")
leia(Celsius)
Fahrenheit<-(Celsius*1.8+32)
Escreva("ºC equivale a:",Fahrenheit, "ºF")

Escreva("Insira a quantidade de graus Fahrenheit:")
leia(Fahrenheit)
Celsius<-(Fahrenheit-32/9)
Escreva("ºF equivale a:",Celsius, "ºC")
Fimalgoritmo