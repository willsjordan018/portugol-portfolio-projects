Algoritmo "acrescimo_de_10%"

Var
percentagem,aumento:real
salarioactual:real
salarionovo:real
Inicio
percentagem<-10.0
escreva("Insira o valor do seu salário atual:")
leia(salarioactual)
aumento<-(salarioactual*percentagem)/100
salarionovo<-salarioactual+aumento
escreva("O seu novo salario é de:",salarionovo)
Fimalgoritmo